<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/seeker_wallet_background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/seeker_wallet_title"
            android:textColor="#14F195"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/seeker_wallet_summary"
            android:textColor="#C9FFF1"
            android:textSize="15sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@drawable/seeker_wallet_card"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="18dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/seeker_wallet_balance_label"
                    android:textColor="#8AF6D4"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/wallet_balance"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/seeker_wallet_balance_placeholder"
                    android:textColor="#FFFFFF"
                    android:textSize="26sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/seeker_wallet_cluster_label"
                    android:textColor="#8AF6D4"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/wallet_cluster"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:id="@+id/wallet_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/seeker_wallet_card"
            android:padding="18dp"
            android:textColor="#E8FFF9"
            android:textSize="15sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/seeker_wallet_address_label"
            android:textColor="#14F195"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/wallet_address"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/seeker_wallet_card"
            android:padding="18dp"
            android:textColor="#E8FFF9"
            android:textSize="14sp" />

        <Button
            android:id="@+id/wallet_connect"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/seeker_wallet_connect" />

        <Button
            android:id="@+id/wallet_send"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/seeker_wallet_send" />

        <EditText
            android:id="@+id/wallet_send_recipient"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:autofillHints=""
            android:background="@drawable/seeker_wallet_card"
            android:hint="@string/seeker_wallet_send_recipient_hint"
            android:inputType="textNoSuggestions"
            android:padding="16dp"
            android:textColor="#E8FFF9"
            android:textColorHint="#FF9945FF" />

        <TextView
            android:id="@+id/wallet_send_resolution"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textColor="#BFECE4"
            android:textSize="13sp"
            android:visibility="gone" />

        <EditText
            android:id="@+id/wallet_send_amount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:autofillHints=""
            android:background="@drawable/seeker_wallet_card"
            android:hint="@string/seeker_wallet_send_amount_hint"
            android:inputType="numberDecimal"
            android:padding="16dp"
            android:text="0.01"
            android:textColor="#E8FFF9"
            android:textColorHint="#FF9945FF" />

        <Button
            android:id="@+id/wallet_receive"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/seeker_wallet_receive" />

        <Button
            android:id="@+id/wallet_close"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:text="@string/seeker_wallet_close" />
    </LinearLayout>
</ScrollView>
